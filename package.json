{
  "name": "flihub",
  "version": "1.0.0",
  "description": "FliHub - Business OS for FLI Golf",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "migrate": "tsx src/lib/migrations/migrate.ts",
    "import-data": "tsx src/lib/migrations/import-data.ts",
    "test:backup": "tsx scripts/backup-before-seed.ts",
    "test:seed": "tsx scripts/seed-test-data.ts",
    "test:seed:quick": "tsx scripts/seed-test-data.ts quick",
    "test:seed:full": "tsx scripts/seed-test-data.ts full",
    "test:restore": "tsx scripts/restore-from-seed-backup.ts latest",
    "test:flow": "npm run test:backup && npm run test:seed:quick"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FLI-Golf/FliHub.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/FLI-Golf/FliHub/issues"
  },
  "homepage": "https://github.com/FLI-Golf/FliHub#readme",
  "devDependencies": {
    "@internationalized/date": "^3.10.1",
    "@lucide/svelte": "^0.561.0",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.49.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/papaparse": "^5.5.2",
    "autoprefixer": "^10.4.23",
    "bits-ui": "^2.14.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "lucide-svelte": "^0.562.0",
    "postcss": "^8.5.6",
    "svelte": "^5.46.1",
    "svelte-check": "^4.3.5",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "dependencies": {
    "@types/d3": "^7.4.3",
    "csv-parse": "^6.1.0",
    "d3": "^7.9.0",
    "mode-watcher": "^1.1.0",
    "papaparse": "^5.5.3",
    "pocketbase": "^0.26.5",
    "zod": "^4.2.1",
    "zod-form-data": "^3.0.1"
  }
}
